rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserExists() {
      return isAuthenticated() && exists(currentUserPath());
    }

    function currentUserData() {
      return currentUserExists()
        ? get(currentUserPath()).data
        : null;
    }

    function currentRole() {
      return currentUserData() != null && currentUserData().role != null
        ? currentUserData().role
        : 'customer';
    }

    function isActiveUser() {
      return isAuthenticated()
        && currentUserExists()
        && currentUserData().isActive != false
        && currentUserData().disabledByAdmin != true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && currentRole() == 'admin';
    }

    function isActiveAdmin() {
      return isAdmin() && isActiveUser();
    }

    function isSelfOrAdmin(userId) {
      return isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    function isActiveSelfOrAdmin(userId) {
      return isActiveUser() && (isOwner(userId) || isAdmin());
    }

    function requestData(requestId) {
      return exists(/databases/$(database)/documents/requests/$(requestId))
        ? get(/databases/$(database)/documents/requests/$(requestId)).data
        : null;
    }

    function invoiceData(invoiceId) {
      return exists(/databases/$(database)/documents/invoices/$(invoiceId))
        ? get(/databases/$(database)/documents/invoices/$(invoiceId)).data
        : null;
    }

    function isRequestParticipant(data) {
      return isActiveUser()
        && data != null
        && (
          isAdmin() ||
          request.auth.uid == data.customerId ||
          request.auth.uid == data.workerId ||
          request.auth.uid == data.listedByWorkerId ||
          request.auth.uid == data.driverId ||
          request.auth.uid == data.assignedDriverId
        );
    }

    function canReadRequest(data) {
      return isRequestParticipant(data);
    }

    function canMutateRequest(data) {
      return isRequestParticipant(data);
    }

    function isFinanceParticipant(data) {
      return isActiveUser()
        && data != null
        && (
          isAdmin() ||
          request.auth.uid == data.customerId ||
          request.auth.uid == data.workerId ||
          request.auth.uid == data.driverId ||
          request.auth.uid == data.assignedDriverId
        );
    }

    match /users/{userId} {
      allow read: if isActiveUser() || isAdmin();

      allow create: if isAuthenticated() && (
        isOwner(userId) ||
        isAdmin()
      );

      allow update: if isAuthenticated() && (
        isAdmin() ||
        (
          isActiveUser() &&
          isOwner(userId) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.isActive == resource.data.isActive &&
          request.resource.data.disabledByAdmin == resource.data.disabledByAdmin
        )
      );

      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read, update, delete: if isActiveSelfOrAdmin(userId);
        allow create: if isActiveSelfOrAdmin(userId);
      }

      match /deviceTokens/{tokenId} {
        allow read, write: if isActiveSelfOrAdmin(userId);
      }

      match /favorites/{favoriteId} {
        allow read, write: if isActiveSelfOrAdmin(userId);
      }

      match /favoriteWorkers/{workerId} {
        allow read, write: if isActiveSelfOrAdmin(userId);
      }
    }

    match /vehicles/{vehicleId} {
      allow read: if isActiveUser();

      allow create: if isActiveUser() && (
        isAdmin() ||
        request.resource.data.workerId == request.auth.uid
      );

      allow update, delete: if isActiveUser() && (
        isAdmin() ||
        resource.data.workerId == request.auth.uid ||
        request.resource.data.workerId == request.auth.uid
      );
    }

    match /workers/{workerId} {
      allow read: if isActiveUser();
      allow write: if isActiveSelfOrAdmin(workerId);
    }

    match /drivers/{driverId} {
      allow read: if isActiveUser();
      allow write: if isActiveSelfOrAdmin(driverId);
    }

    match /requests/{requestId} {
      allow read: if canReadRequest(resource.data);

      allow create: if isActiveUser() && (
        isAdmin() ||
        request.resource.data.customerId == request.auth.uid
      );

      allow update: if canMutateRequest(resource.data);

      allow delete: if isActiveUser() && (
        isAdmin() ||
        resource.data.customerId == request.auth.uid
      );

      match /offers/{offerId} {
        allow read: if canReadRequest(requestData(requestId));

        allow create, update: if isActiveUser() && (
          isAdmin() ||
          isRequestParticipant(requestData(requestId))
        );

        allow delete: if false;
      }

      match /timeline/{eventId} {
        allow read: if canReadRequest(requestData(requestId));

        allow create: if isActiveUser() && (
          isAdmin() ||
          isRequestParticipant(requestData(requestId))
        );

        allow update, delete: if false;
      }
    }

    match /invoices/{invoiceId} {
      allow read: if isFinanceParticipant(resource.data);
      allow create, update, delete: if isActiveAdmin();
    }

    match /financial_transactions/{transactionId} {
      allow read: if isFinanceParticipant(resource.data);
      allow create, update, delete: if isActiveAdmin();
    }

    match /payment_sessions/{sessionId} {
      allow read: if isActiveUser() && (
        isAdmin() ||
        request.auth.uid == resource.data.createdBy ||
        isFinanceParticipant(resource.data)
      );

      allow create: if isActiveUser()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.invoiceId is string
        && invoiceData(request.resource.data.invoiceId) != null
        && isFinanceParticipant(invoiceData(request.resource.data.invoiceId))
        && request.resource.data.amount == invoiceData(request.resource.data.invoiceId).totalAmount
        && request.resource.data.currency == invoiceData(request.resource.data.invoiceId).currency;

      allow update, delete: if isActiveAdmin();
    }

    match /commissions/{commissionId} {
      allow read: if isActiveUser() && (
        isAdmin() ||
        request.auth.uid == resource.data.workerId
      );

      allow create, update: if isActiveUser() && (
        isAdmin() ||
        request.resource.data.workerId == request.auth.uid
      );

      allow delete: if isActiveAdmin();
    }

    match /chats/{chatId} {
      allow read, create, update: if isActiveUser();
      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if isActiveUser();
        allow update, delete: if false;
      }
    }
  }
}