rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function currentUserData() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function currentRole() {
      return isAuthenticated() &&
        currentUserData() != null &&
        currentUserData().role != null
        ? currentUserData().role
        : 'customer';
    }

    function isAdmin() {
      return isAuthenticated() && currentRole() == 'admin';
    }

    function isSelfOrAdmin(userId) {
      return isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    function requestData(requestId) {
      return exists(/databases/$(database)/documents/requests/$(requestId))
        ? get(/databases/$(database)/documents/requests/$(requestId)).data
        : null;
    }

    function invoiceData(invoiceId) {
      return exists(/databases/$(database)/documents/invoices/$(invoiceId))
        ? get(/databases/$(database)/documents/invoices/$(invoiceId)).data
        : null;
    }

    function isRequestParticipant(data) {
      return isAuthenticated() &&
        data != null && (
          isAdmin() ||
          request.auth.uid == data.customerId ||
          request.auth.uid == data.workerId ||
          request.auth.uid == data.driverId ||
          request.auth.uid == data.assignedDriverId
        );
    }

    function canReadRequest(data) {
      return isRequestParticipant(data);
    }

    function canMutateRequest(data) {
      return isRequestParticipant(data);
    }

    function isFinanceParticipant(data) {
      return isAuthenticated() &&
        data != null && (
          isAdmin() ||
          request.auth.uid == data.customerId ||
          request.auth.uid == data.workerId ||
          request.auth.uid == data.driverId ||
          request.auth.uid == data.assignedDriverId
        );
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isSelfOrAdmin(userId);
      allow update, delete: if isSelfOrAdmin(userId);

      match /notifications/{notificationId} {
        allow read, update, delete: if isSelfOrAdmin(userId);
        allow create: if isSelfOrAdmin(userId);
      }

      match /deviceTokens/{tokenId} {
        allow read, write: if isSelfOrAdmin(userId);
      }

      match /favorites/{favoriteId} {
        allow read, write: if isSelfOrAdmin(userId);
      }

      match /favoriteWorkers/{workerId} {
        allow read, write: if isSelfOrAdmin(userId);
      }
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isAdmin() ||
        request.resource.data.workerId == request.auth.uid
      );
      allow update, delete: if isAuthenticated() && (
        isAdmin() ||
        resource.data.workerId == request.auth.uid ||
        request.resource.data.workerId == request.auth.uid
      );
    }

    match /workers/{workerId} {
      allow read: if isAuthenticated();
      allow write: if isSelfOrAdmin(workerId);
    }

    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isSelfOrAdmin(driverId);
    }

    match /requests/{requestId} {
      allow read: if canReadRequest(resource.data);
      allow create: if isAuthenticated() && (
        isAdmin() ||
        request.resource.data.customerId == request.auth.uid
      );
      allow update: if canMutateRequest(resource.data);
      allow delete: if isAuthenticated() && (
        isAdmin() ||
        resource.data.customerId == request.auth.uid
      );

      match /offers/{offerId} {
        allow read: if canReadRequest(requestData(requestId));
        allow create, update: if isAuthenticated() && (
          isAdmin() ||
          isRequestParticipant(requestData(requestId))
        );
        allow delete: if false;
      }

      match /timeline/{eventId} {
        allow read: if canReadRequest(requestData(requestId));
        allow create: if isAuthenticated() && (
          isAdmin() ||
          isRequestParticipant(requestData(requestId))
        );
        allow update, delete: if false;
      }
    }

    match /invoices/{invoiceId} {
      allow read: if isFinanceParticipant(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /financial_transactions/{transactionId} {
      allow read: if isFinanceParticipant(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /payment_sessions/{sessionId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        request.auth.uid == resource.data.createdBy ||
        isFinanceParticipant(resource.data)
      );

      allow create: if isAuthenticated() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.invoiceId is string &&
        invoiceData(request.resource.data.invoiceId) != null &&
        isFinanceParticipant(invoiceData(request.resource.data.invoiceId)) &&
        request.resource.data.amount == invoiceData(request.resource.data.invoiceId).totalAmount &&
        request.resource.data.currency == invoiceData(request.resource.data.invoiceId).currency;

      allow update, delete: if isAdmin();
    }

    match /commissions/{commissionId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        request.auth.uid == resource.data.workerId
      );
      allow create, update: if isAuthenticated() && (
        isAdmin() ||
        request.resource.data.workerId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
  allow read: if isAuthenticated()
    && resource.data.participants is list
    && request.auth.uid in resource.data.participants;

  allow create: if isAuthenticated()
    && request.resource.data.participants is list
    && request.resource.data.participants.size() == 2
    && request.auth.uid in request.resource.data.participants;

  allow update: if isAuthenticated()
    && resource.data.participants is list
    && request.auth.uid in resource.data.participants;

  allow delete: if false;

  match /messages/{messageId} {
    allow read: if isAuthenticated()
      && exists(/databases/$(database)/documents/chats/$(chatId))
      && request.auth.uid in
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

    allow create: if isAuthenticated()
      && exists(/databases/$(database)/documents/chats/$(chatId))
      && request.auth.uid in
        get(/databases/$(database)/documents/chats/$(chatId)).data.participants
      && request.resource.data.senderId == request.auth.uid
      && request.resource.data.text is string
      && request.resource.data.text.size() > 0
      && request.resource.data.type == 'text';

    allow update: if false;
    allow delete: if false;
  }
}
  }
}